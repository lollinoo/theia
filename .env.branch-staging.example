# =============================================================================
# Theia - Branch Staging Environment
# =============================================================================
# Optional overrides for branch-specific staging stacks.
# Defaults work out of the box — only customize if needed.
#
# Usage: make branch-staging BRANCH=fix/login-timeout
# =============================================================================

FRONTEND_PORT=3002
BACKEND_PORT=8082
LOG_LEVEL=debug
THEIA_ENCRYPTION_KEY=
DOCKER_CONFIG_PATH=/root/.docker/config.json
