# =============================================================================
# Theia -- Production Environment Variables
# =============================================================================
# Copy to .env.prod:  cp .env.prod.example .env.prod
# Start prod stack:   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# GHCR Authentication (one-time setup):
#   1. Create a GitHub PAT with read:packages scope
#      https://github.com/settings/tokens/new?scopes=read:packages
#   2. Run: echo $GHCR_PAT | docker login ghcr.io -u YOUR_GITHUB_USERNAME --password-stdin
# =============================================================================

# Image version to deploy.
# Set this to a published semver release tag, e.g., 1.5.1.
THEIA_VERSION=1.5.1

# Port the frontend (nginx) listens on. Default: 80
FRONTEND_PORT=80

# Internal backend listen port used by the frontend proxy. Default: 8080
# Not host-published by the default production compose stack.
BACKEND_PORT=8080

# Backend log verbosity: debug, info, warn, error. Default: info
LOG_LEVEL=info

# Enables production runtime validation for required operator-provided secrets.
THEIA_DEPLOYMENT_ENV=production

# Backend encryption key (32 bytes). REQUIRED.
# Generate locally and keep only in .env.prod or your secret manager.
THEIA_ENCRYPTION_KEY=

# Database driver: postgres is the required production default.
# SQLite is only for explicit demo/lab/small-install exceptions.
THEIA_DB_DRIVER=postgres

# Required explicit opt-in for any SQLite exception path.
# Leave unset for the standard postgres path.
THEIA_ALLOW_SQLITE_SMALL_INSTALL=

# SQLite file path inside the backend container.
# Used only when an operator explicitly opts in to SQLite small-install mode.
THEIA_DB_PATH=/data/theia.db

# Local app data directory inside the backend container
THEIA_DATA_DIR=/data

# PostgreSQL DSN used by the production backend. REQUIRED.
# Operator-provided secret-bearing value; leave blank in this tracked example.
THEIA_DB_DSN=

# Bundled PostgreSQL service settings used by the default production compose stack.
POSTGRES_DB=theia
POSTGRES_USER=theia
# REQUIRED when using the bundled PostgreSQL service.
# Operator-generated secret-bearing value; leave blank in this tracked example.
POSTGRES_PASSWORD=

# Optional host exposure for the bundled PostgreSQL service
POSTGRES_BIND_ADDR=127.0.0.1
POSTGRES_HOST_PORT=5432
