# =============================================================================
# Theia -- Staging Environment Variables
# =============================================================================
# Copy to .env.staging:  cp .env.staging.example .env.staging
# Start staging stack:   docker compose -f docker-compose.staging.yml --env-file .env.staging up -d
#
# GHCR Authentication (one-time setup):
#   1. Create a GitHub PAT with read:packages scope
#      https://github.com/settings/tokens/new?scopes=read:packages
#   2. Run: echo $GHCR_PAT | docker login ghcr.io -u YOUR_GITHUB_USERNAME --password-stdin
#   3. Watchtower reads ~/.docker/config.json automatically
# =============================================================================

# Docker image tag. Default: staging (master branch).
# Set to a branch name to test that branch (e.g., fix-links, feat-new-thing).
IMAGE_TAG=staging

# Staging frontend port (different from production to allow co-existence)
FRONTEND_PORT=3001

# Internal backend listen port used by the frontend proxy. Default: 8081
# Not host-published by the default staging compose stack.
BACKEND_PORT=8081

# Backend log verbosity: debug, info, warn, error. Default: info
LOG_LEVEL=info

# Enables staging runtime validation for required operator-provided secrets.
THEIA_DEPLOYMENT_ENV=staging

# Backend credential encryption keyring. REQUIRED in staging.
# Generate high-entropy secrets locally and keep them only in .env.staging or your secret manager.
# Format: THEIA_ENCRYPTION_KEYS=<key-id>=<secret>[,<key-id>=<secret>...]
THEIA_ENCRYPTION_KEY_ID=kid-staging-2026-06
THEIA_ENCRYPTION_KEYS=kid-staging-2026-06=
# Rotation:
# 1. Add a new key with a new key ID to THEIA_ENCRYPTION_KEYS.
# 2. Set THEIA_ENCRYPTION_KEY_ID to the new key ID.
# 3. Start Theia so startup migration rewraps stored credentials.
# 4. Keep old key IDs configured during the backup/restore validation window.
# 5. Remove old keys only after migration, a fresh backup, and restore validation pass.
# Legacy fallback for existing deployments only:
# THEIA_ENCRYPTION_KEY=

# Password-session signing and token hashing secret. REQUIRED in staging.
# Generate a high-entropy value locally and keep it out of source control.
THEIA_SESSION_SECRET=

# Dedicated bearer token for /metrics. REQUIRED in staging.
THEIA_METRICS_TOKEN=

# Optional comma-separated exact browser origins for direct backend access.
# Same-host requests through the frontend proxy are allowed without this.
# Include LAN/IP origins used by browsers, e.g. http://192.168.1.30:3000.
THEIA_ALLOWED_ORIGINS=

# Optional directory inside the backend container containing Bridge Connector binaries.
# Required for User Settings connector downloads; leave blank to disable downloads.
THEIA_BRIDGE_BINARIES_DIR=

# Local app data directory inside the backend container
THEIA_DATA_DIR=/data

# PostgreSQL DSN used by the staging backend. REQUIRED.
# Operator-provided secret-bearing value; leave blank in this tracked example.
THEIA_DB_DSN=

# Bundled PostgreSQL service settings used by the default staging compose stack.
POSTGRES_DB=theia
POSTGRES_USER=theia
# REQUIRED when using the bundled PostgreSQL service.
# Operator-generated secret-bearing value; leave blank in this tracked example.
POSTGRES_PASSWORD=

# Optional host exposure for the bundled PostgreSQL service
POSTGRES_BIND_ADDR=127.0.0.1
POSTGRES_HOST_PORT=5433

# Path to Docker config.json for Watchtower GHCR auth
# Default: /root/.docker/config.json (for root user)
# Change if running as non-root: /home/USERNAME/.docker/config.json
DOCKER_CONFIG_PATH=/root/.docker/config.json
