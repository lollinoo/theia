# =============================================================================
# Theia -- Production Environment Variables
# =============================================================================
# Copy to .env.prod:  cp .env.prod.example .env.prod
# Start prod stack:   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# GHCR Authentication (one-time setup):
#   1. Create a GitHub PAT with read:packages scope
#      https://github.com/settings/tokens/new?scopes=read:packages
#   2. Run: echo $GHCR_PAT | docker login ghcr.io -u YOUR_GITHUB_USERNAME --password-stdin
# =============================================================================

# Image version to deploy (REQUIRED -- no default)
# Use the semver tag published by CI, e.g., 1.5.1
THEIA_VERSION=1.5.1

# Port the frontend (nginx) listens on. Default: 80
FRONTEND_PORT=80

# Port the backend API listens on. Default: 8080
BACKEND_PORT=8080

# Backend log verbosity: debug, info, warn, error. Default: info
LOG_LEVEL=info

# Backend encryption key (32 bytes). Generate with: openssl rand -base64 32
THEIA_ENCRYPTION_KEY=

# Database driver: postgres is the production reference path
THEIA_DB_DRIVER=postgres

# SQLite file path inside the backend container.
# Used only for local fallback and SQLite-based maintenance workflows.
THEIA_DB_PATH=/data/theia.db

# Local app data directory inside the backend container
THEIA_DATA_DIR=/data

# PostgreSQL DSN used by the production backend.
# The default points at the bundled postgres service in docker-compose.prod.yml.
THEIA_DB_DSN=postgres://theia:change-me@postgres:5432/theia?sslmode=disable

# Bundled PostgreSQL service settings for --profile postgres
POSTGRES_DB=theia
POSTGRES_USER=theia
POSTGRES_PASSWORD=change-me

# Optional host exposure for the bundled PostgreSQL service
POSTGRES_BIND_ADDR=127.0.0.1
POSTGRES_HOST_PORT=5432
