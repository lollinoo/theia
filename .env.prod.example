# =============================================================================
# Theia — Production Environment Variables
# =============================================================================
# Copy to .env.prod and adjust values before starting the production stack:
#   cp .env.prod.example .env.prod
#
# Load with:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# =============================================================================

# Port the frontend (nginx) listens on. Default: 80
FRONTEND_PORT=80

# Port the backend API listens on. Default: 8080
# Only expose externally if you are NOT using the nginx frontend proxy.
BACKEND_PORT=8080

# Backend log verbosity: debug, info, warn, error. Default: info
LOG_LEVEL=info

# Backend encryption key (32 bytes). Generate with: openssl rand -base64 32
THEIA_ENCRYPTION_KEY=test

